# ==============================
# Environment Variable Template
# ==============================
# Copy this file to `.env` in the project root:
#   cp phase1-setup/.env.example .env
#
# Then fill in your credentials.
# ==============================

# --- Groq LLM API ---
GROQ_API_KEY=

# --- Reddit API (for PRAW) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SpotifyReviewEngine/1.0

# --- Optional ---
# LOG_LEVEL=INFO
# BATCH_SIZE=50
